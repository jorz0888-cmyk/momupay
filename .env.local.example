# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored. The same variables must be configured
# in the Vercel project's Environment Variables for production
# deploys (see README.md for details).

# Supabase project URL (publishable, safe to expose in browser bundle)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase publishable / anon key (publishable, safe to expose in browser bundle)
# Do NOT use the service_role key here — only the publishable key.
VITE_SUPABASE_KEY=sb_publishable_xxxxx
