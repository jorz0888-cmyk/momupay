# vite-plugin-pwa@1.2.0 declares peer support for Vite 3-7, but we're
# on Vite 8. The plugin works at runtime (verified with `npm run build`
# emitting a correct workbox SW); this flag tells npm to allow the
# install instead of failing with ERESOLVE on Vercel and for fresh
# clones. Drop this once vite-plugin-pwa publishes a Vite 8-compatible
# release.
legacy-peer-deps=true
